# Copy this file to .env.local and fill in your values.
# The app runs without this — AI Builder will simply fail to generate trips
# if the key is absent or invalid.

# Google Gemini API key — used by /ai-builder to generate trip itineraries.
# Get one at https://aistudio.google.com/apikey
NEXT_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here

# Go backend base URL — used by the Next.js auth proxy on the server.
# For local testing, point this at your backend server, for example:
API_URL=http://localhost:8080
